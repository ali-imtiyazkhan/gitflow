generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Conflict {
  id            String   @id @default(uuid())
  owner         String
  repo          String
  sourceBranch  String
  targetBranch  String
  status        String   @default("open")
  hunks         Json  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([owner, repo])
}
